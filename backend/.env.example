# Environment Variables
# Copy this file to .env and fill in real values

JWT_SECRET_KEY=change-this-to-a-long-random-secret
DB_PATH=./chat.db
UPLOAD_DIR=./uploads
PORT=8080

# WebAuthn — must match your public domain
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:3000

# Admin setup — keep this SECRET, only you should know it
ADMIN_SETUP_TOKEN=change-this-to-your-secret-admin-token
